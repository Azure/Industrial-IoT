<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <EnableSdkContainerSupport>true</EnableSdkContainerSupport>
    <Nullable>enable</Nullable>
    <TieredPGO>true</TieredPGO>
  </PropertyGroup>
  <PropertyGroup>
    <ContainerRepository>iotedge/opc-publisher</ContainerRepository>
    <ContainerBaseImage>mcr.microsoft.com/dotnet/aspnet:10.0-azurelinux3.0-distroless</ContainerBaseImage>
  </PropertyGroup>
  <ItemGroup>
    <ContainerEnvironmentVariable Include="ASPNETCORE_HTTP_PORTS" Value="" />
    <ContainerEnvironmentVariable Include="DOTNET_ReadyToRun" Value="0" />
    <ContainerEnvironmentVariable Include="DOTNET_TieredPGO" Value="1" />
    <ContainerEnvironmentVariable Include="DOTNET_TC_QuickJitForLoops" Value="1" />
  </ItemGroup>
  <ItemGroup>
    <ContainerPort Include="9071" Type="tcp" />
    <ContainerPort Include="9072" Type="tcp" />
    <ContainerPort Include="80" Type="tcp" />
    <ContainerPort Include="443" Type="tcp" />
  </ItemGroup>
  <ItemGroup>
    <ProjectCapability Include="AzureIoTEdgeModule" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="pki\**" />
    <EmbeddedResource Remove="pki\**" />
    <None Remove="pki\**" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Furly.Extensions.AspNetCore" />
    <PackageReference Include="Furly.Extensions.Mqtt" />
    <PackageReference Include="Furly.Extensions.Dapr" />
    <PackageReference Include="Furly.Extensions.MessagePack" />
    <PackageReference Include="Furly.Azure.EventHubs" />
    <PackageReference Include="Furly.Azure.IoT" />
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Core" />
    <PackageReference Include="Furly.Tunnel" />
    <PackageReference Include="Mono.Options" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="OpenTelemetry.Exporter.Prometheus.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Azure.IIoT.OpcUa.Publisher\src\Azure.IIoT.OpcUa.Publisher.csproj" />
  </ItemGroup>
</Project>
